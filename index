/* ══════════════════════════════════════════════════
   게임 상태
══════════════════════════════════════════════════ */
let cards = [], openIds = [], matchedSet = new Set();
let plays = 0, locked = false;
let timerInterval = null, startTime = null, elapsed = 0;
let nickname = '';

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}
function fmt(s) {
  if (s == null) return '--:--';
  return `${Math.floor(s/60).toString().padStart(2,'0')}:${Math.floor(s%60).toString().padStart(2,'0')}`;
}
function esc(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ── 타이머 ── */
function startTimer() {
  if (startTime !== null) return;
  startTime = Date.now() - elapsed*1000;
  timerInterval = setInterval(() => {
    elapsed = (Date.now()-startTime)/1000;
    document.getElementById('timer-display').textContent = fmt(elapsed);
  }, 200);
}
function stopTimer() {
  clearInterval(timerInterval);
  if (startTime) elapsed = (Date.now()-startTime)/1000;
}
function resetTimer() {
  clearInterval(timerInterval);
  timerInterval = null; startTime = null; elapsed = 0;
  document.getElementById('timer-display').textContent = '00:00';
}

/* ── 뒷면 SVG ── */
function backSVG() {
  return `<svg class="back-svg" viewBox="0 0 76 118" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="dots" x="0" y="0" width="12" height="12" patternUnits="userSpaceOnUse">
        <circle cx="6" cy="6" r="1.8" fill="rgba(99,102,241,0.3)"/>
      </pattern>
    </defs>
    <rect width="76" height="118" fill="url(#dots)"/>
    <text x="38" y="62" text-anchor="middle" dominant-baseline="middle"
      font-size="26" fill="rgba(99,102,241,0.25)" font-weight="bold">🧪</text>
  </svg>`;
}

/* ── 카드 DOM 생성 ── */
function makeCard(c) {
  const slot = document.createElement('div');
  slot.className = 'card-slot card-appear';
  slot.dataset.id = c.id;

  const inner = document.createElement('div');
  inner.className = 'card-inner';

  // 뒷면
  const back = document.createElement('div');
  back.className = 'card-face card-back';
  back.innerHTML = backSVG();

  // 앞면
  const front = document.createElement('div');

  if (c.type === 'formula') {
    front.className = 'card-face card-formula';
    front.innerHTML = `<span class="formula-text">${c.fHtml}</span>`;
  } else if (c.type === 'molecule') {
    front.className = 'card-face card-name';
    front.innerHTML = c.molSvg + `<span class="name-text" style="font-size:clamp(7px,1.5vw,10px);color:#3730a3;font-weight:700;">${c.label}</span>`;
  } else {
    front.className = 'card-face card-name';
    front.innerHTML = `<span class="name-text">${c.name}</span>`;
  }

  inner.appendChild(back);
  inner.appendChild(front);
  slot.appendChild(inner);
  slot.addEventListener('click', () => onCardClick(c.id));
  return slot;
}

/* ── 게임 초기화: 44쌍 중 15쌍 랜덤 선정 ── */
function initGame() {
  const selected = shuffle(POOL).slice(0, 15);

  const raw = [];
  selected.forEach(item => {
    // 화학식 카드
    raw.push({
      id: `f-${item.id}`,
      pairId: `n-${item.id}`,
      type: 'formula',
      fHtml: item.fHtml,
    });
    // 이름/모형 카드
    if (item.hasMol) {
      raw.push({
        id: `n-${item.id}`,
        pairId: `f-${item.id}`,
        type: 'molecule',
        molSvg: item.nameSvg,
        label: item.nameHtml.replace(/<[^>]+>/g,''),  // strip tags for label
      });
    } else {
      raw.push({
        id: `n-${item.id}`,
        pairId: `f-${item.id}`,
        type: 'name',
        name: item.name,
      });
    }
  });

  cards = shuffle(raw);
  openIds = []; matchedSet = new Set();
  plays = 0; locked = false;
  resetTimer();

  const pa = document.getElementById('play-area');
  pa.innerHTML = '';
  pa.style.gridTemplateColumns = `repeat(6, var(--cw))`;

  cards.forEach((c, i) => {
    const el = makeCard(c);
    el.style.animationDelay = (i * 0.035) + 's';
    pa.appendChild(el);
  });

  document.getElementById('h-matched').textContent = '0';
  document.getElementById('header-info').style.display = 'flex';
  document.getElementById('start-screen').style.display = 'none';
  document.getElementById('game-screen').style.display  = 'flex';
  document.getElementById('win-banner').classList.add('hidden');
}

/* ── 카드 클릭 ── */
function onCardClick(id) {
  if (locked) return;
  if (matchedSet.has(id)) return;
  if (openIds.includes(id)) return;
  if (openIds.length >= 2) return;

  startTimer();

  const slot = document.querySelector(`.card-slot[data-id="${id}"]`);
  slot.classList.add('flipped');
  openIds.push(id);

  if (openIds.length < 2) return;

  plays++;
  locked = true;

  const [id1, id2] = openIds;
  const c1 = cards.find(c => c.id === id1);
  const c2 = cards.find(c => c.id === id2);
  const isMatch = c1 && c2 && c1.pairId === id2 && c2.pairId === id1;

  if (isMatch) {
    setTimeout(() => {
      [id1, id2].forEach(id => {
        const s = document.querySelector(`.card-slot[data-id="${id}"]`);
        s.classList.remove('flipped');
        s.classList.add('matched');
      });
      matchedSet.add(id1);
      matchedSet.add(id2);
      openIds = [];
      locked  = false;
      document.getElementById('h-matched').textContent = matchedSet.size / 2;

      if (matchedSet.size === 30) {
        stopTimer();
        saveScore(nickname, elapsed, plays);
        setTimeout(showWin, 500);
      }
    }, 600);
  } else {
    const s1 = document.querySelector(`.card-slot[data-id="${id1}"]`);
    const s2 = document.querySelector(`.card-slot[data-id="${id2}"]`);
    s1.classList.add('do-shake');
    s2.classList.add('do-shake');
    setTimeout(() => {
      s1.classList.remove('flipped','do-shake');
      s2.classList.remove('flipped','do-shake');
      openIds = [];
      locked  = false;
    }, 900);
  }
}

/* ── 완성 ── */
function showWin() {
  document.getElementById('w-time').textContent = fmt(elapsed);
  document.getElementById('win-banner').classList.remove('hidden');
}

/* ── 랭킹 ── */
function saveScore(nick, time, p) {
  let lb = getLB();
  lb.push({ nick: nick||'익명', time, plays:p, date: new Date().toLocaleDateString('ko-KR') });
  lb.sort((a,b) => a.time - b.time);
  localStorage.setItem('chem_lb', JSON.stringify(lb.slice(0,50)));
}
function getLB() {
  try { return JSON.parse(localStorage.getItem('chem_lb')) || []; } catch { return []; }
}
function renderLB() {
  const lb = getLB();
  const list = document.getElementById('lb-list');
  if (!lb.length) {
    list.innerHTML = '<li class="lb-empty">아직 기록이 없어요!</li>';
    return;
  }
  list.innerHTML = lb.slice(0,20).map((r,i) => `
    <li class="lb-item">
      <div class="lb-rank ${i===0?'r1':i===1?'r2':i===2?'r3':''}">${i+1}</div>
      <div class="lb-name">${esc(r.nick)}</div>
      <div class="lb-time">${fmt(r.time)}</div>
      <div class="lb-plays">${r.plays}회 · ${r.date}</div>
    </li>`).join('');
}

/* ── 이벤트 ── */
document.getElementById('btn-start').addEventListener('click', () => {
  nickname = document.getElementById('nick-input').value.trim() || '익명';
  initGame();
});
document.getElementById('nick-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') document.getElementById('btn-start').click();
});
document.getElementById('btn-again').addEventListener('click', () => {
  document.getElementById('win-banner').classList.add('hidden');
  document.getElementById('game-screen').style.display = 'none';
  document.getElementById('start-screen').style.display = 'flex';
  document.getElementById('header-info').style.display  = 'none';
});
document.getElementById('btn-trophy').addEventListener('click', () => {
  renderLB();
  document.getElementById('lb-overlay').classList.remove('hidden');
});
document.getElementById('btn-win-rank').addEventListener('click', () => {
  document.getElementById('win-banner').classList.add('hidden');
  renderLB();
  document.getElementById('lb-overlay').classList.remove('hidden');
});
document.getElementById('close-lb').addEventListener('click', () =>
  document.getElementById('lb-overlay').classList.add('hidden'));
document.getElementById('lb-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('lb-overlay'))
    document.getElementById('lb-overlay').classList.add('hidden');
});
</script>
