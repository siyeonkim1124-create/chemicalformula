  { id:'au',  fHtml:'Au',  name:'금' },
  { id:'pb',  fHtml:'Pb',  name:'납' },

  // ── 양이온
  { id:'hion',    fHtml:'H<sup>+</sup>',             name:'수소 이온' },
  { id:'mgion',   fHtml:'Mg<sup>2+</sup>',            name:'마그네슘 이온' },
  { id:'nh4ion',  fHtml:'NH<sub>4</sub><sup>+</sup>', name:'암모늄 이온' },
  { id:'naion',   fHtml:'Na<sup>+</sup>',             name:'나트륨 이온' },
  { id:'agion',   fHtml:'Ag<sup>+</sup>',             name:'은 이온' },
  { id:'caion',   fHtml:'Ca<sup>2+</sup>',            name:'칼슘 이온' },
  { id:'pbion',   fHtml:'Pb<sup>2+</sup>',            name:'납 이온' },
  { id:'kion',    fHtml:'K<sup>+</sup>',              name:'칼륨 이온' },
  { id:'fe2ion',  fHtml:'Fe<sup>2+</sup>',            name:'철 이온' },
  { id:'cuion',   fHtml:'Cu<sup>2+</sup>',            name:'구리 이온' },
  { id:'baion',   fHtml:'Ba<sup>2+</sup>',            name:'바륨 이온' },

  // ── 음이온
  { id:'clion',   fHtml:'Cl<sup>-</sup>',              name:'염화 이온' },
  { id:'oion',    fHtml:'O<sup>2-</sup>',              name:'산화 이온' },
